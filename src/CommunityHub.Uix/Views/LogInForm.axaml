<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CommunityHub.Uix.Views.LogInForm"
        Title="Prijava" Height="400" Width="300"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Korisničko ime:" FontSize="14" Margin="0,0,0,5"/>
        <TextBox Grid.Row="0" x:Name="UsernameTextBox" FontSize="14" Padding="5" Margin="0,30,0,0"/>

        <TextBlock Grid.Row="2" Text="Lozinka:" FontSize="14" Margin="0,0,0,5"/>
        <TextBox Grid.Row="2" x:Name="PasswordTextBox" FontSize="14" Padding="5" Margin="0,30,0,0"
                 PasswordChar="*"/>

        <TextBlock Grid.Row="4" x:Name="ErrorMessageTextBlock"
                   Foreground="Red" FontSize="12"
                   TextWrapping="Wrap" IsVisible="False"/>

        <Button Grid.Row="6" Content="Prijavi se"
                FontSize="14" Padding="10"
                Click="LoginButton_Click"/>
    </Grid>
</Window>
