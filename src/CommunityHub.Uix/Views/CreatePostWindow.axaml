<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CommunityHub.Uix.Views.CreatePostWindow"
        Title="Nova objava" Height="400" Width="500"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Naslov:" FontSize="14" Margin="0,0,0,5"/>
        <TextBox Grid.Row="0" x:Name="TitleTextBox" TextChanged="OnTitleTextBox_TextChanged"
                 FontSize="14" Padding="5" Margin="0,25,0,0"/>

        <TextBlock Grid.Row="1" x:Name="ValidationErrorTextBlock"
                   Text="Naslov mora imati bar 3 karaktera"
                   Foreground="Red" FontSize="12"
                   Margin="0,5,0,0"
                   IsVisible="False"/>

        <TextBlock Grid.Row="2" Text="Sadržaj:" FontSize="14" Margin="0,15,0,5"/>
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="ContentTextBox"
                     FontSize="14" Padding="5"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"/>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="SaveButton" Content="Sačuvaj"
                    FontSize="14" Padding="15,8"
                    Margin="0,0,10,0"
                    IsEnabled="False"
                    Click="SaveButton_Click"/>
            <Button Content="Otkaži"
                    FontSize="14" Padding="15,8"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
