<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CommunityHub.Uix.Views.ProfileWindow"
        Title="Profil" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="15">
            <Grid>
                <TextBlock x:Name="UserInfoTextBlock"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Nova objava"
                            Click="NewPostButton_Click"
                            Padding="15,8"
                            Margin="0,0,10,0"
                            FontSize="14"/>
                    <Button Content="Početna"
                            Click="HomeButton_Click"
                            Padding="15,8"
                            Margin="0,0,10,0"
                            FontSize="14"/>
                    <Button Content="Odjavi se"
                            Click="LogoutButton_Click"
                            Padding="15,8"
                            FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PostsItemsControl" Margin="40,20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1"
                                Margin="0,0,0,15"
                                Padding="20" CornerRadius="5">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding Content}"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Opacity="0.8"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy. HH:mm\}}"
                                           FontSize="12"
                                           Opacity="0.6"
                                           FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Error overlay (replaces MessageBox) -->
        <Border x:Name="ErrorOverlay" Grid.RowSpan="2"
                Background="#80000000" IsVisible="False">
            <Border Background="White" CornerRadius="8"
                    Padding="30" MaxWidth="400" MaxHeight="200"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Greška" FontSize="18" FontWeight="Bold"
                               Foreground="Red" Margin="0,0,0,10"/>
                    <TextBlock x:Name="ErrorMessageText" TextWrapping="Wrap"
                               FontSize="14" Margin="0,0,0,15"/>
                    <Button Content="U redu" HorizontalAlignment="Right"
                            Padding="15,8" Click="ErrorOkButton_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
